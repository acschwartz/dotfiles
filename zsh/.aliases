# Oh My Zsh users are encouraged to define aliases within 
# a top-level file in the $ZSH_CUSTOM folder, with .zsh extension.

# Examples:
# - $ZSH_CUSTOM/aliases.zsh
# - $ZSH_CUSTOM/macos.zsh
# ______________________________________________________________________________


# ==============================================================================
# =                             Aliases                                        =
# ==============================================================================

## OMZ Examples
# alias zshconfig="code ~/.zshrc"
# alias ohmyzsh="code ~/.oh-my-zsh"

## 🐚 Shell
alias omzr="omz reload"     # Reload Zsh config without restarting the terminal.

## ⚡️ Shortcuts
alias lo="ls -1"

## 🐙 Git
alias unstage="git restore --staged ."
alias gs="git status"
alias gst=""    # overwrite plugin alias to train myself out of using it
#alias gst="git stash"
alias gcm="git commit -m"
alias gpp="git pull && git push"

## Gitignore.io OMZ plugin
alias gitignore="gi"

## 🐍 Python
alias py="python"
alias pip="pip3"
alias python="python3"
alias py3="python3"


## 📁 Directories
alias dev="cd $HOME/dev; ls -1"
alias dotfiles="cd $HOME/dev/dotfiles; ls -1"

## ☁️ iCloud Folder
alias ic="cd $HOME/Library/Mobile\ Documents/com~apple~CloudDocs; ls -1"

## 📁 PARA System
alias para="echo $'\nPARA System'; cd $HOME/Library/Mobile\ Documents/com~apple~CloudDocs/PARA; ls -1; echo '' "

alias para-p="para; 
cd 1\ \ 🎯\ Projects\ \ \[short-term\]/ ; 
echo $'\nProjects\n' ; 
ls -1 ;
echo $'\n' "

alias para-a="para; 
cd 2\ 🌱\ Areas\ \ \ \ \[ongoing\ responsibility\]/ ; 
echo $'\nAreas of Resonsibility\n' ;
ls -1 ;
echo $'\n' "

alias para-r="para; 
cd 3\ 📚\ Resources\ \ \ \ \[topics,\ interests,\ hobbies\]/ ; 
echo $'\nResources\n' ;
ls -1 ;
echo $'\n' "

alias para-arch="para;
cd 4\ 🗄️\ Archive/ ;
echo $'\nArchive\n' ;
ls -1 ;
echo $'\n' "



# ==============================================================================
# =                🧠 Alias Debugging & Inspection Tips                        =
# ==============================================================================
# ➡️ To list all currently defined aliases (if using Oh My Zsh):
#   alias

# ➡️ To figure out where your Zsh aliases are defined (including plugins):
#   zsh -ixc : -o sourcetrace 2>&1 | grep -w alias

# ➡️ To check if a name (like an alias, function, or command) is already taken:
#   which <name>   # Shows if it's an executable or alias (e.g. `which reload`)
#   type <name>    # Tells you if it's an alias, function, builtin, or file
#
# Examples:
#   which reload    → not found (safe to use)
#   type reload     → alias (already defined)
# ______________________________________________________________________________
